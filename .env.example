# ===== GUDO Space 環境變數（複製成 .env 或設在 Vercel 專案設定）=====

# Supabase（專案 → Settings → API）
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...        # 後端專用，勿放前端／勿進版控
SUPABASE_MEDIA_BUCKET=media                     # Storage 的 public bucket 名稱

# Resend（寄信；resend.com → API Keys）
RESEND_API_KEY=re_xxx
RESEND_FROM="GUDO Space <noreply@你的網域>"     # 需在 Resend 驗證寄件網域
NOTIFY_EMAIL=你的收件信箱@example.com            # 新預約通知寄到這裡

# 後台
GUDO_SECRET=請填一段長亂碼                       # session 金鑰，固定不變
GUDO_ADMIN_USER=admin
GUDO_ADMIN_PASS=請設一組強密碼                    # 首次部署自動建立管理員
